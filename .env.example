# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Contract Addresses (deployed on your target network)
NEXT_PUBLIC_FACTORY_ADDRESS=0xYourFactoryContractAddress
NEXT_PUBLIC_USDT_ADDRESS=0xYourUSDTContractAddress

# RPC URLs (optional, defaults to public endpoints)
NEXT_PUBLIC_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key

# Enable testnets (set to "true" for Sepolia testnet)
NEXT_PUBLIC_ENABLE_TESTNETS=false
